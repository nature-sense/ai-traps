traps/runtimes/*/yolo26n.rknn

# ONNX source models in runtime directories (large, managed separately)
traps/runtimes/*/yolo26n.onnx

# Compiled trap binaries in runtime directories (build artifacts)
traps/runtimes/*/ai-trap-detection

